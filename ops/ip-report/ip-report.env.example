# Copy to /etc/ip-report.env on the robot, fill in, then: sudo chmod 600 /etc/ip-report.env
# Gmail requires an APP PASSWORD (not your login password):
#   https://myaccount.google.com/apppasswords  (2FA must be on)

SMTP_USER=your-gmail-address@gmail.com
SMTP_APP_PASSWORD=xxxxxxxxxxxxxxxx
MAIL_TO=bobchenyx@gmail.com
MAIL_FROM=your-gmail-address@gmail.com

# Defaults (only override if not using Gmail):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
